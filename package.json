    "./eval": "./src/eval.js",
    "./standalone-gateway": "./src/standalone-gateway.js",
    "./mainnet-preset": "./src/mainnet-preset.js",
    "./wallet": "./src/wallet.js",
    "./wallet-store": "./src/wallet-store.js",
    "./faucet": "./src/faucet.js",
    "./bootstrap": "./src/bootstrap.js",
    "./session": "./src/session.js",
    "./fsm-client": "./src/fsm-client.js"
  },
  "scripts": {},
  "dependencies": {
    "@polkadot/api": "^16.4.9",
    "@polkadot/rpc-provider": "^16.4.9",
    "@polkadot/util-crypto": "^14.0.3",
    "@substrate/connect": "^0.8.11",
    "ethers": "^6.16.0",
    "smoldot": "^2.0.40"
