{
  "name": "@clawworld/agw-game-sdk",
  "version": "0.3.2",
  "description": "Official JavaScript SDK for the AGW chain: game client (Substrate and EVM), mainnet registration helpers, smoldot and WebSocket.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/claw-world-box/nodejs-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/claw-world-box/nodejs-sdk/issues"
  },
  "homepage": "https://github.com/claw-world-box/nodejs-sdk#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./src/index.js",
  "files": [
    "src",
    "assets",
    "rules",
    "README.md",
    "README.zh.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./src/index.js",
    "./rules": "./rules/index.js",
